rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserData() {
      return currentUserDoc().data;
    }

    function isApproved() {
      return signedIn() && currentUserDoc().exists() && currentUserData().status == "approved";
    }

    function isAdmin() {
      return isApproved() && currentUserData().role == "admin";
    }

    function isCoordinator() {
      return isApproved() && currentUserData().role == "coordinator";
    }

    function isCoordinatorOrAdmin() {
      return isCoordinator() || isAdmin();
    }

    function sameDepartment(dept) {
      return isCoordinatorOrAdmin() && (isAdmin() || currentUserData().department == dept);
    }

    function hasList(data, fieldName) {
      return data.keys().hasAny([fieldName]) && data[fieldName] is list;
    }

    function assignedToMe(data) {
      return isApproved() && (
        (hasList(data, "assignedToUids") && data.assignedToUids.hasAny([request.auth.uid])) ||
        (hasList(data, "assignedToEmails") && data.assignedToEmails.hasAny([request.auth.token.email]))
      );
    }

    function reportCoworker(data) {
      return isApproved() && hasList(data, "coworkerUids") && data.coworkerUids.hasAny([request.auth.uid]);
    }

    // Volunteer self-claims an unassigned archive unit. Only the two
    // assignee arrays may change; the current unit must have no assignees;
    // the new arrays must be exactly the caller's uid and lowercased email.
    function selfClaimArchiveUnit() {
      return isApproved() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["assignedToUids", "assignedToEmails"]) &&
        (!hasList(resource.data, "assignedToUids") || resource.data.assignedToUids.size() == 0) &&
        (!hasList(resource.data, "assignedToEmails") || resource.data.assignedToEmails.size() == 0) &&
        hasList(request.resource.data, "assignedToUids") &&
        request.resource.data.assignedToUids.size() == 1 &&
        request.resource.data.assignedToUids.hasAny([request.auth.uid]) &&
        hasList(request.resource.data, "assignedToEmails") &&
        request.resource.data.assignedToEmails.size() == 1 &&
        request.resource.data.assignedToEmails.hasAny([request.auth.token.email.lower()]);
    }

    // Volunteer releases a unit they had self-claimed (sole assignee).
    // Only the two assignee arrays may change; they go from exactly
    // [caller.uid] / [caller.email] to empty.
    function selfReleaseArchiveUnit() {
      return isApproved() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["assignedToUids", "assignedToEmails"]) &&
        hasList(resource.data, "assignedToUids") &&
        resource.data.assignedToUids.size() == 1 &&
        resource.data.assignedToUids.hasAny([request.auth.uid]) &&
        hasList(request.resource.data, "assignedToUids") &&
        request.resource.data.assignedToUids.size() == 0 &&
        hasList(request.resource.data, "assignedToEmails") &&
        request.resource.data.assignedToEmails.size() == 0;
    }

    // Report-first flow: when a volunteer submits a report, the same batch
    // touches the linked archive unit. The unit update is restricted to a
    // small denormalization set (status + last-activity metadata + an opt-in
    // digitized flag). Same diff().affectedKeys().hasOnly([...]) pattern as
    // the self-claim rule above.
    function reportFirstUnitUpdate() {
      return isApproved() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "lastActivityAt",
          "lastReporterId",
          "lastReporterName",
          "lastReportNotePreview",
          "digitized",
          "latestReportAt",
          "updatedAt"
        ]) &&
        request.resource.data.lastReporterId == request.auth.uid;
    }

    // Report-first "liste dışı / yeni iş" path: a volunteer can create a
    // pending_review archive unit so their report has somewhere to attach.
    // Strictly limited — coordinators triage before the unit becomes work.
    function volunteerCreatePendingUnit() {
      return isApproved() &&
        request.resource.data.status == "pending_review" &&
        request.resource.data.createdByVolunteerId == request.auth.uid;
    }

    // workDate is the YYYY-MM-DD calendar date the volunteer says the work
    // happened. Distinct from createdAt (when the report was submitted) so
    // backdated reports stay accurate. Format check stays cheap and runs on
    // every create/update; the 30-day-back window is also enforced here as a
    // server-side backstop against a malicious client posting ancient dates.
    function isValidWorkDateFormat(d) {
      return d is string && d.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    // Parse a YYYY-MM-DD string into a UTC-midnight Timestamp so rules can
    // compare it against request.time. Assumes isValidWorkDateFormat(d) was
    // already checked — split + int conversions would otherwise throw.
    function workDateAsTimestamp(d) {
      return timestamp.date(
        int(d.split('-')[0]),
        int(d.split('-')[1]),
        int(d.split('-')[2])
      );
    }

    // workDate must be no more than 30 days before request.time and no later
    // than 1 day after request.time. The +1d on the future side allows for
    // browser timezone skew (Istanbul is UTC+3) without surprising volunteers
    // who pick "today" near local midnight.
    function isValidWorkDateRange(d) {
      return isValidWorkDateFormat(d) &&
        workDateAsTimestamp(d) >= request.time - duration.value(30, 'd') &&
        workDateAsTimestamp(d) <= request.time + duration.value(1, 'd');
    }

    // Kullanıcının kendi dokümanında güncelleyebileceği alanlar.
    // role, status, department gibi yetki alanları yalnızca admin/koordinatör tarafından değiştirilebilir.
    function userSelfEditableFields() {
      return [
        "fullName",
        "phone",
        "notes",
        "skillsText",
        "lastSeenAt",
        "lastReportAt",
        "reportCount7d",
        "reportCount30d",
        "counterWindowStart",
        "rhythm",
        "telegramId",
        "telegramLinkedAt",
        "telegramLastSeenAt",
        "updatedAt"
      ];
    }

    match /users/{uid} {
      allow create: if signedIn() && (request.auth.uid == uid || isAdmin());

      // Read: self, or any coordinator/admin. The same-department restriction
      // is intentionally NOT applied to /users reads — specialty matching
      // and availability lookups need to span departments.
      allow read: if signedIn() && (
        request.auth.uid == uid ||
        isCoordinatorOrAdmin()
      );

      // specialty / availabilityDays / canWorkInPerson are admin-only on write.
      // Volunteers cannot self-edit them (not in userSelfEditableFields()) and
      // coordinators are blocked by the affectedKeys() guard below — they
      // request changes through an admin.
      //
      // Telegram-link fields (telegramId, telegramLinkedAt, telegramLastSeenAt)
      // are added to userSelfEditableFields above so the volunteer can self-link
      // and self-unlink. Bot writes go through the Apps Script service account
      // and bypass rules entirely. The cross-department coordinator clause at
      // the end lets staff fix up telegram links for any user without needing
      // department match — useful when an unlinking request comes in via DM.
      allow update: if signedIn() && (
        (request.auth.uid == uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(userSelfEditableFields())) ||
        isAdmin() ||
        (isCoordinator() &&
          resource.data.department == currentUserData().department &&
          request.resource.data.department == resource.data.department &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["specialty", "availabilityDays", "canWorkInPerson"])) ||
        (isCoordinator() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "telegramId", "telegramLinkedAt", "telegramLastSeenAt", "updatedAt"
          ]))
      );

      allow delete: if isAdmin();
    }

    match /preregistered/{email} {
      allow read, delete: if signedIn() && (request.auth.token.email == email || isAdmin());
      allow create, update: if isAdmin();
    }

    match /projectPeople/{personId} {
      allow read, create, update, delete: if isCoordinatorOrAdmin();
    }

    match /projects/{projectId} {
      allow read: if isApproved();
      allow create, update, delete: if isCoordinatorOrAdmin();
    }

    match /availability/{availabilityId} {
      allow read, create, update, delete: if isCoordinatorOrAdmin();
    }

    match /communicationPlans/{planId} {
      allow read: if isApproved();
      allow create, update, delete: if isCoordinatorOrAdmin();
    }

    match /archiveUnits/{unitId} {
      // Read: staff always; volunteers see the units they are assigned to AND,
      // for the report-first typeahead, units in projects they are part of.
      // Today the project membership check is implicit (PNB-only) — when we
      // add explicit memberships we will gate read on
      // request.auth.uid in resource.data.projectMembers or similar.
      allow read: if isApproved();
      allow create: if isCoordinatorOrAdmin() || volunteerCreatePendingUnit();
      allow update: if isCoordinatorOrAdmin() || (
        assignedToMe(resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "blockerNote",
          "latestReportAt",
          "updatedAt"
        ])
      ) || selfClaimArchiveUnit() || selfReleaseArchiveUnit() || reportFirstUnitUpdate();
      allow delete: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read: if isApproved() && (
        isAdmin() ||
        (isCoordinator() && resource.data.department == currentUserData().department) ||
        resource.data.assignedToUid == request.auth.uid ||
        resource.data.assignedToEmail == request.auth.token.email
      );

      allow create: if isCoordinatorOrAdmin() && (
        isAdmin() || request.resource.data.department == currentUserData().department
      );

      allow update: if isCoordinatorOrAdmin() && (
        isAdmin() || resource.data.department == currentUserData().department
      );

      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      // Owner identity is checked against either the legacy userUid field
      // (quick / detailed forms) or the report-first volunteerId field.
      // Volunteers must match userUid/volunteerId; coordinators/admins can
      // submit on behalf of any volunteer (Prompt: backdating + on-behalf).
      // submittedBy is required and records who actually filed the report:
      // for self-submitted reports it equals volunteerId; for coordinator-on-
      // behalf reports it equals the coordinator's uid.
      allow create: if isApproved() &&
        request.resource.data.submittedBy == request.auth.uid &&
        isValidWorkDateRange(request.resource.data.workDate) &&
        (
          (
            (request.resource.data.userUid == request.auth.uid &&
              request.resource.data.userEmail == request.auth.token.email) ||
            (request.resource.data.volunteerId == request.auth.uid &&
              request.resource.data.userUid == request.auth.uid)
          ) ||
          isCoordinatorOrAdmin()
        );

      allow read: if isApproved() && (
        isCoordinatorOrAdmin() ||
        resource.data.userUid == request.auth.uid ||
        resource.data.volunteerId == request.auth.uid ||
        reportCoworker(resource.data)
      );

      // Update branches (Prompt: edit history + 24h volunteer self-edit):
      //   1. Admin — can edit anything.
      //   2. Coordinator/admin — no time limit; volunteerId/createdAt/
      //      submittedBy stay locked so the audit trail can't be rewritten.
      //   3. Volunteer self-edit — only their own report, only within 24h of
      //      createdAt, and the same identity invariants apply.
      // For every branch a CHANGED workDate must still pass the 30-day check;
      // an unchanged workDate is allowed through even if it's now older than
      // 30 days (e.g. a 31-day-old report whose volunteer-self-edit window is
      // already closed but a coordinator decides to fix a typo on the note).
      allow update: if isAdmin() ||
        (isCoordinatorOrAdmin() &&
          request.resource.data.volunteerId == resource.data.volunteerId &&
          request.resource.data.createdAt == resource.data.createdAt &&
          request.resource.data.submittedBy == resource.data.submittedBy &&
          (request.resource.data.workDate == resource.data.workDate ||
            isValidWorkDateRange(request.resource.data.workDate))) ||
        (isApproved() &&
          resource.data.userUid == request.auth.uid &&
          request.resource.data.userUid == resource.data.userUid &&
          request.resource.data.volunteerId == resource.data.volunteerId &&
          request.resource.data.createdAt == resource.data.createdAt &&
          request.resource.data.submittedBy == resource.data.submittedBy &&
          request.time < resource.data.createdAt + duration.value(24, 'h') &&
          (request.resource.data.workDate == resource.data.workDate ||
            isValidWorkDateRange(request.resource.data.workDate)));

      allow delete: if isAdmin() || resource.data.userUid == request.auth.uid;
    }

    match /announcements/{announcementId} {
      allow read: if isApproved();
      allow create, update: if isCoordinatorOrAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow create: if isApproved();
      allow read, update, delete: if isApproved() && (
        resource.data.toUid == request.auth.uid ||
        isAdmin()
      );
    }

    match /activityLogs/{logId} {
      allow read: if isCoordinatorOrAdmin();
      allow create: if isApproved();
      allow update, delete: if isAdmin();
    }

    // Public landing page surfaces. These two collections exist purely to
    // expose privacy-safe aggregates and a denormalized recent-activity
    // ticker to unauthenticated visitors of the public site. They are
    // populated by the authenticated dashboard at report-submit time.
    //
    // Why a separate collection: Firestore rules grant read at the document
    // level, not the field level. Exposing /reports publicly would leak
    // volunteerName, note text, and links. So we denormalize ONLY the public-
    // safe shape into /publicTicker and /publicProjectStats and keep
    // /reports + /archiveUnits locked.

    match /publicTicker/{entryId} {
      // Anyone can read. Each entry contains createdAt + effort +
      // materialCategory + projectId + volunteerToken (a per-month hash of
      // the volunteer's uid that lets the page count distinct contributors
      // without revealing identity).
      allow read: if true;

      // Approved volunteers create their own ticker entry alongside their
      // report. Schema is locked so a malicious / compromised client cannot
      // smuggle volunteer names or note text in.
      allow create: if isApproved() &&
        request.resource.data.keys().hasOnly([
          "createdAt", "effort", "materialCategory", "projectId", "volunteerToken"
        ]) &&
        request.resource.data.effort in ["small", "medium", "large"] &&
        request.resource.data.volunteerToken is string &&
        request.resource.data.volunteerToken.size() <= 64 &&
        request.resource.data.materialCategory is string &&
        request.resource.data.projectId is string;

      // Admins can prune / fix old entries; nobody else can edit them.
      allow update, delete: if isAdmin();
    }

    // Telegram bot session storage. Apps Script writes via service account
    // (bypasses rules); no client writes them. Admins get read-only access
    // for the Bakım Telegram tanılama diagnostic; everyone else is locked
    // out, since the doc body contains in-flight conversation state.
    match /telegramSessions/{telegramId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // 6-digit one-shot codes the volunteer creates from Anasayfa to link
    // their Telegram account. Apps Script consumes the code via service
    // account on bot side. Code TTL is 10 minutes; the client checks expiry
    // for its own UI but the bot also revalidates server-side. Admin read
    // access supports the Bakım expired-code housekeeping count.
    match /telegramLinkCodes/{code} {
      allow create: if isApproved() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.keys().hasOnly(["uid", "createdAt", "expiresAt"]);
      allow read: if (isApproved() && resource.data.uid == request.auth.uid) || isAdmin();
      allow delete, update: if false;
    }

    match /publicProjectStats/{projectId} {
      // Aggregate doc per project — totalPages, donePages, totalUnits,
      // doneUnits, updatedAt. Numbers only; no identifiers.
      allow read: if true;

      // Approved volunteers and the importer (admin) can refresh the
      // aggregate. Schema locked to prevent extraneous fields from being
      // smuggled into a public read.
      allow create, update: if isApproved() &&
        request.resource.data.keys().hasOnly([
          "totalPages", "donePages", "totalUnits", "doneUnits", "updatedAt"
        ]) &&
        request.resource.data.totalPages is number &&
        request.resource.data.donePages is number &&
        request.resource.data.totalUnits is number &&
        request.resource.data.doneUnits is number;

      allow delete: if isAdmin();
    }
  }
}
