rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserData() {
      return currentUserDoc().data;
    }

    function isApproved() {
      return signedIn() && currentUserDoc().exists() && currentUserData().status == "approved";
    }

    function isAdmin() {
      return isApproved() && currentUserData().role == "admin";
    }

    function isCoordinator() {
      return isApproved() && currentUserData().role == "coordinator";
    }

    function isCoordinatorOrAdmin() {
      return isCoordinator() || isAdmin();
    }

    function sameDepartment(dept) {
      return isCoordinatorOrAdmin() && (isAdmin() || currentUserData().department == dept);
    }

    function hasList(data, fieldName) {
      return data.keys().hasAny([fieldName]) && data[fieldName] is list;
    }

    function assignedToMe(data) {
      return isApproved() && (
        (hasList(data, "assignedToUids") && data.assignedToUids.hasAny([request.auth.uid])) ||
        (hasList(data, "assignedToEmails") && data.assignedToEmails.hasAny([request.auth.token.email]))
      );
    }

    function reportCoworker(data) {
      return isApproved() && hasList(data, "coworkerUids") && data.coworkerUids.hasAny([request.auth.uid]);
    }

    match /users/{uid} {
      allow create: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow read: if signedIn() && (
        request.auth.uid == uid ||
        isAdmin() ||
        (isCoordinator() && resource.data.department == currentUserData().department)
      );

      allow update: if signedIn() && (
        request.auth.uid == uid ||
        isAdmin() ||
        (isCoordinator() &&
          resource.data.department == currentUserData().department &&
          request.resource.data.department == resource.data.department)
      );

      allow delete: if isAdmin();
    }

    match /preregistered/{email} {
      allow read, delete: if signedIn() && (request.auth.token.email == email || isAdmin());
      allow create, update: if isAdmin();
    }

    match /teamProfiles/{uid} {
      allow read: if isApproved();
      allow create, update, delete: if isCoordinatorOrAdmin();
    }

    match /projectPeople/{personId} {
      allow read, create, update, delete: if isCoordinatorOrAdmin();
    }

    match /projects/{projectId} {
      allow read: if isApproved();
      allow create, update, delete: if isCoordinatorOrAdmin();
    }

    match /availability/{availabilityId} {
      allow read, create, update, delete: if isCoordinatorOrAdmin();
    }

    match /communicationPlans/{planId} {
      allow read: if isApproved();
      allow create, update, delete: if isCoordinatorOrAdmin();
    }

    match /archiveUnits/{unitId} {
      allow read: if isCoordinatorOrAdmin() || assignedToMe(resource.data);
      allow create: if isCoordinatorOrAdmin();
      allow update: if isCoordinatorOrAdmin() || (
        assignedToMe(resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "blockerNote",
          "latestReportAt",
          "updatedAt"
        ])
      );
      allow delete: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read: if isApproved() && (
        isAdmin() ||
        (isCoordinator() && resource.data.department == currentUserData().department) ||
        resource.data.assignedToUid == request.auth.uid ||
        resource.data.assignedToEmail == request.auth.token.email
      );

      allow create: if isCoordinatorOrAdmin() && (
        isAdmin() || request.resource.data.department == currentUserData().department
      );

      allow update: if isCoordinatorOrAdmin() && (
        isAdmin() || resource.data.department == currentUserData().department
      );

      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if isApproved() && (
        (request.resource.data.userUid == request.auth.uid &&
          request.resource.data.userEmail == request.auth.token.email) ||
        isCoordinatorOrAdmin()
      );

      allow read: if isApproved() && (
        isCoordinatorOrAdmin() ||
        resource.data.userUid == request.auth.uid ||
        reportCoworker(resource.data)
      );

      allow update: if isApproved() && (
        isCoordinatorOrAdmin() ||
        (resource.data.userUid == request.auth.uid &&
          request.resource.data.userUid == resource.data.userUid &&
          request.resource.data.status == "submitted")
      );

      allow delete: if isAdmin() || resource.data.userUid == request.auth.uid;
    }

    match /announcements/{announcementId} {
      allow read: if isApproved();
      allow create, update: if isCoordinatorOrAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow create: if isApproved();
      allow read, update, delete: if isApproved() && (
        resource.data.toUid == request.auth.uid ||
        isAdmin()
      );
    }

    match /activityLogs/{logId} {
      allow read: if isCoordinatorOrAdmin();
      allow create: if isApproved();
      allow update, delete: if isAdmin();
    }
  }
}
