rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserData() {
      return currentUserDoc().data;
    }

    function isApproved() {
      return signedIn() && currentUserDoc().exists() && currentUserData().status == "approved";
    }

    function isAdmin() {
      return isApproved() && currentUserData().role == "admin";
    }

    function isCoordinator() {
      return isApproved() && currentUserData().role == "coordinator";
    }

    function isCoordinatorOrAdmin() {
      return isCoordinator() || isAdmin();
    }

    function sameDepartment(dept) {
      return isCoordinatorOrAdmin() && (isAdmin() || currentUserData().department == dept);
    }

    function hasList(data, fieldName) {
      return data.keys().hasAny([fieldName]) && data[fieldName] is list;
    }

    function assignedToMe(data) {
      return isApproved() && (
        (hasList(data, "assignedToUids") && data.assignedToUids.hasAny([request.auth.uid])) ||
        (hasList(data, "assignedToEmails") && data.assignedToEmails.hasAny([request.auth.token.email]))
      );
    }

    function reportCoworker(data) {
      return isApproved() && hasList(data, "coworkerUids") && data.coworkerUids.hasAny([request.auth.uid]);
    }

    // Volunteer self-claims an unassigned archive unit. Only the two
    // assignee arrays may change; the current unit must have no assignees;
    // the new arrays must be exactly the caller's uid and lowercased email.
    function selfClaimArchiveUnit() {
      return isApproved() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["assignedToUids", "assignedToEmails"]) &&
        (!hasList(resource.data, "assignedToUids") || resource.data.assignedToUids.size() == 0) &&
        (!hasList(resource.data, "assignedToEmails") || resource.data.assignedToEmails.size() == 0) &&
        hasList(request.resource.data, "assignedToUids") &&
        request.resource.data.assignedToUids.size() == 1 &&
        request.resource.data.assignedToUids.hasAny([request.auth.uid]) &&
        hasList(request.resource.data, "assignedToEmails") &&
        request.resource.data.assignedToEmails.size() == 1 &&
        request.resource.data.assignedToEmails.hasAny([request.auth.token.email.lower()]);
    }

    // Volunteer releases a unit they had self-claimed (sole assignee).
    // Only the two assignee arrays may change; they go from exactly
    // [caller.uid] / [caller.email] to empty.
    function selfReleaseArchiveUnit() {
      return isApproved() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["assignedToUids", "assignedToEmails"]) &&
        hasList(resource.data, "assignedToUids") &&
        resource.data.assignedToUids.size() == 1 &&
        resource.data.assignedToUids.hasAny([request.auth.uid]) &&
        hasList(request.resource.data, "assignedToUids") &&
        request.resource.data.assignedToUids.size() == 0 &&
        hasList(request.resource.data, "assignedToEmails") &&
        request.resource.data.assignedToEmails.size() == 0;
    }

    // Report-first flow: when a volunteer submits a report, the same batch
    // touches the linked archive unit. The unit update is restricted to a
    // small denormalization set (status + last-activity metadata + an opt-in
    // digitized flag). Same diff().affectedKeys().hasOnly([...]) pattern as
    // the self-claim rule above.
    function reportFirstUnitUpdate() {
      return isApproved() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "lastActivityAt",
          "lastReporterId",
          "lastReporterName",
          "lastReportNotePreview",
          "digitized",
          "latestReportAt",
          "updatedAt"
        ]) &&
        request.resource.data.lastReporterId == request.auth.uid;
    }

    // Report-first "liste dışı / yeni iş" path: a volunteer can create a
    // pending_review archive unit so their report has somewhere to attach.
    // Strictly limited — coordinators triage before the unit becomes work.
    function volunteerCreatePendingUnit() {
      return isApproved() &&
        request.resource.data.status == "pending_review" &&
        request.resource.data.createdByVolunteerId == request.auth.uid;
    }

    // Kullanıcının kendi dokümanında güncelleyebileceği alanlar.
    // role, status, department gibi yetki alanları yalnızca admin/koordinatör tarafından değiştirilebilir.
    function userSelfEditableFields() {
      return [
        "fullName",
        "phone",
        "notes",
        "skillsText",
        "lastSeenAt",
        "lastReportAt",
        "reportCount7d",
        "reportCount30d",
        "counterWindowStart",
        "rhythm",
        "updatedAt"
      ];
    }

    match /users/{uid} {
      allow create: if signedIn() && (request.auth.uid == uid || isAdmin());

      // Read: self, or any coordinator/admin. The same-department restriction
      // is intentionally NOT applied to /users reads — specialty matching
      // and availability lookups need to span departments.
      allow read: if signedIn() && (
        request.auth.uid == uid ||
        isCoordinatorOrAdmin()
      );

      // specialty / availabilityDays / canWorkInPerson are admin-only on write.
      // Volunteers cannot self-edit them (not in userSelfEditableFields()) and
      // coordinators are blocked by the affectedKeys() guard below — they
      // request changes through an admin.
      allow update: if signedIn() && (
        (request.auth.uid == uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(userSelfEditableFields())) ||
        isAdmin() ||
        (isCoordinator() &&
          resource.data.department == currentUserData().department &&
          request.resource.data.department == resource.data.department &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["specialty", "availabilityDays", "canWorkInPerson"]))
      );

      allow delete: if isAdmin();
    }

    match /preregistered/{email} {
      allow read, delete: if signedIn() && (request.auth.token.email == email || isAdmin());
      allow create, update: if isAdmin();
    }

    match /projectPeople/{personId} {
      allow read, create, update, delete: if isCoordinatorOrAdmin();
    }

    match /projects/{projectId} {
      allow read: if isApproved();
      allow create, update, delete: if isCoordinatorOrAdmin();
    }

    match /availability/{availabilityId} {
      allow read, create, update, delete: if isCoordinatorOrAdmin();
    }

    match /communicationPlans/{planId} {
      allow read: if isApproved();
      allow create, update, delete: if isCoordinatorOrAdmin();
    }

    match /archiveUnits/{unitId} {
      // Read: staff always; volunteers see the units they are assigned to AND,
      // for the report-first typeahead, units in projects they are part of.
      // Today the project membership check is implicit (PNB-only) — when we
      // add explicit memberships we will gate read on
      // request.auth.uid in resource.data.projectMembers or similar.
      allow read: if isApproved();
      allow create: if isCoordinatorOrAdmin() || volunteerCreatePendingUnit();
      allow update: if isCoordinatorOrAdmin() || (
        assignedToMe(resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "blockerNote",
          "latestReportAt",
          "updatedAt"
        ])
      ) || selfClaimArchiveUnit() || selfReleaseArchiveUnit() || reportFirstUnitUpdate();
      allow delete: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read: if isApproved() && (
        isAdmin() ||
        (isCoordinator() && resource.data.department == currentUserData().department) ||
        resource.data.assignedToUid == request.auth.uid ||
        resource.data.assignedToEmail == request.auth.token.email
      );

      allow create: if isCoordinatorOrAdmin() && (
        isAdmin() || request.resource.data.department == currentUserData().department
      );

      allow update: if isCoordinatorOrAdmin() && (
        isAdmin() || resource.data.department == currentUserData().department
      );

      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      // Owner identity is checked against either the legacy userUid field
      // (quick / detailed forms) or the report-first volunteerId field.
      // Both must point at the caller and the report must declare a project
      // the caller can write to. Today every approved volunteer can write to
      // pnb; explicit memberships (users/{uid}.projects[]) will tighten this.
      allow create: if isApproved() && (
        (
          (request.resource.data.userUid == request.auth.uid &&
            request.resource.data.userEmail == request.auth.token.email) ||
          (request.resource.data.volunteerId == request.auth.uid &&
            request.resource.data.userUid == request.auth.uid)
        ) ||
        isCoordinatorOrAdmin()
      );

      allow read: if isApproved() && (
        isCoordinatorOrAdmin() ||
        resource.data.userUid == request.auth.uid ||
        resource.data.volunteerId == request.auth.uid ||
        reportCoworker(resource.data)
      );

      // Update / delete: report-first reports are owner-immutable from the
      // client (intentional — corrections happen by writing a new report).
      // Legacy detailed reports can still be edited by their owner while
      // status is "submitted". Admins can do anything.
      allow update: if isAdmin() || isCoordinatorOrAdmin() ||
        (isApproved() &&
          resource.data.userUid == request.auth.uid &&
          request.resource.data.userUid == resource.data.userUid &&
          request.resource.data.status == "submitted");

      allow delete: if isAdmin() || resource.data.userUid == request.auth.uid;
    }

    match /announcements/{announcementId} {
      allow read: if isApproved();
      allow create, update: if isCoordinatorOrAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow create: if isApproved();
      allow read, update, delete: if isApproved() && (
        resource.data.toUid == request.auth.uid ||
        isAdmin()
      );
    }

    match /activityLogs/{logId} {
      allow read: if isCoordinatorOrAdmin();
      allow create: if isApproved();
      allow update, delete: if isAdmin();
    }
  }
}
